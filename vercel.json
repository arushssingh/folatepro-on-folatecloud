{
  "framework": "vite",
  "buildCommand": "tsc && vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/s/:slug", "destination": "/api/site?slug=:slug" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|s/).*)", "destination": "/index.html" }
  ]
}
